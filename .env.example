# Copier ce fichier en ".env" puis ajuster les valeurs.
# Ne jamais committer le fichier ".env" réel dans un dépôt Git.

# --- Bascule pédagogique principale -----------------------------------
# False -> vulnérabilités actives (démonstration "AVANT")
# True  -> correctifs de sécurité appliqués (démonstration "APRÈS")
SECURE_MODE=False

# --- Sécurité générale ---------------------------------------------------
SECRET_KEY=change-moi-avec-une-valeur-aleatoire-longue

# --- Authentification de l'espace d'administration ------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMoiImmediatement!2024

# --- Cookies (activer en HTTPS uniquement) --------------------------------
SESSION_COOKIE_SECURE=False
